{
  "name": "html2pdf",
  "version": "1.2.4",
  "description": "Create PDFs using an Express server and Playwright running in a Docker container",
  "license": "MIT",
  "main": "dist/index.js",
  "scripts": {
    "prebuild": "rimraf dist",
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts src/healthcheck.ts --outdir=dist --bundle --minify --platform=node --target=node24 --packages=external",
    "start": "node dist/index.js",
    "biome:check": "biome check",
    "biome:write": "biome check --write",
    "prepare": "husky || true",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "semantic-release": "semantic-release"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "multer": "^2.2.0",
    "pino-http": "^11.0.0",
    "playwright-core": "1.61.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "semantic-release": "^25.0.5",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@biomejs/biome": "^2.5.1",
    "@playwright/test": "^1.61.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^26.0.0",
    "esbuild": "^0.28.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "npm-run-all": "^4.1.5",
    "pdfjs-dist": "^6.0.227",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audunru/html2pdf.git"
  },
  "keywords": [
    "express",
    "playwright",
    "pdf",
    "docker"
  ],
  "bugs": {
    "url": "https://github.com/audunru/html2pdf/issues"
  },
  "homepage": "https://github.com/audunru/html2pdf",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,md,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
