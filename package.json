{
  "name": "html2pdf",
  "version": "1.1.1",
  "description": "Create PDFs using an Express server and Playwright running in a Docker container",
  "license": "MIT",
  "main": "dist/index.js",
  "scripts": {
    "prebuild": "rimraf dist",
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts src/healthcheck.ts --outdir=dist --bundle --minify --platform=node --target=node24 --packages=external",
    "start": "node dist/index.js",
    "biome:check": "biome check",
    "biome:write": "biome check --write",
    "prepare": "husky || true",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "pino-http": "^11.0.0",
    "playwright-core": "1.59.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@playwright/test": "^1.59.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.2",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.3",
    "npm-run-all": "^4.1.5",
    "pdfjs-dist": "^5.7.284",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audunru/html2pdf.git"
  },
  "keywords": [
    "express",
    "playwright",
    "pdf",
    "docker"
  ],
  "bugs": {
    "url": "https://github.com/audunru/html2pdf/issues"
  },
  "homepage": "https://github.com/audunru/html2pdf",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,md,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
